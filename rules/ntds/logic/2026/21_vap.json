{
  "meta": {
    "event_id": 21,
    "canonical_name": "Ventilator-Associated Pneumonia (VAP)",
    "ntds_year": 2026,
    "version": "1.0.0"
  },
  "gates": [
    {
      "gate_type": "evidence_any",
      "gate_id": "vent_evidence",
      "gate_name": "Evidence of mechanical ventilation",
      "required": true,
      "min_count": 1,
      "query_keys": ["vent_dx"],
      "exclude_noise_keys": ["history_noise"],
      "allowed_sources": ["PHYSICIAN_NOTE", "NURSING_NOTE", "PROGRESS_NOTE", "OPERATIVE_NOTE", "ANESTHESIA_NOTE", "PROCEDURE", "ED_NOTE"],
      "fail_outcome": "NO",
      "fail_reason": "No evidence of mechanical ventilation; VAP requires ventilator use."
    },
    {
      "gate_type": "evidence_any",
      "gate_id": "vap_evidence",
      "gate_name": "Evidence consistent with VAP",
      "required": true,
      "min_count": 2,
      "query_keys": ["vap_dx", "vap_cxr"],
      "exclude_noise_keys": ["history_noise", "vap_negation_noise"],
      "allowed_sources": ["IMAGING", "PHYSICIAN_NOTE", "LAB"],
      "fail_outcome": "NO",
      "fail_reason": "Insufficient evidence for VAP."
    }
  ],
  "exclusions": [
    {
      "gate_type": "exclude_if_any",
      "gate_id": "vap_excl_prophy",
      "gate_name": "Exclude prophylactic ventilator care (scoped)",
      "rule_id": "EXCL_PROPHY",
      "reason": "Prophylactic ventilator-associated care documented.",
      "query_keys": ["prophylaxis_noise"],
      "require_context_keys": ["vap_dx"],
      "proximity_mode": "sentence_window"
    }
  ],
  "summary_overrides": {},
  "debug": "Template-based VAP placeholders"
}
