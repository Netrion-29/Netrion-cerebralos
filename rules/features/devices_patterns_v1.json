  "ett_vent": {
    "absent_wins": true,
    "_comment_absent_wins": "When both present and absent patterns match on the same day, absent wins. Prevents historical narrative (was intubated, copied CXR ETT in place) from overriding explicit extubation documentation.",
    "present": [
      "\\bett\\b",
      "\\bintubat(ed|ion)\\b",
      "\\bmechanical ventilation\\b",
      "\\bon vent\\b",
      "\\bventilator\\b",
      "\\btrach(eostomy)?\\b",
