    "present": [
      "\\bfoley\\b",
      "\\burinary catheter\\b",
      "\\bindwelling catheter\\b",
      "\\burethral catheter\\b",
      "\\bcondom cath(eter)?\\b",
      "\\bexternal catheter\\b",
      "\\bsuprapubic catheter\\b",
      "\\bsuprapubic tube\\b"
    ],
    "absent": [
      "\\bfoley removed\\b",
      "\\bremove foley\\b",
      "\\bdiscontinue foley\\b",
      "\\bno foley\\b",
      "\\bwithout foley\\b",
      "\\bcatheter removed\\b",
      "\\bdiscontinue.*catheter\\b"
    ]
  },
