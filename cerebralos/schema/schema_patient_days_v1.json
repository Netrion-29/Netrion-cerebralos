{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://netrion.systems/schemas/schema_patient_days_v1.json",
  "title": "CerebralOS patient_days.json (Timeline Engine v1)",
  "type": "object",
  "required": ["meta", "days"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["patient_id", "timezone", "arrival_datetime", "day0_date"],
      "properties": {
        "patient_id": { "type": "string", "minLength": 1 },
        "timezone": { "type": "string", "minLength": 1 },
        "arrival_datetime": { "type": "string", "minLength": 1 },
        "day0_date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" }
      },
      "additionalProperties": true
    },
    "days": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["items"],
        "properties": {
          "anchors": {
            "type": "object",
            "properties": {
              "start": { "type": "string" },
              "end": { "type": "string" }
            },
            "additionalProperties": true
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "source_id", "dt_quality", "payload", "provenance"],
              "properties": {
                "type": { "type": "string" },
                "source_id": { "type": "string", "minLength": 1 },
                "dt": { "type": "string" },
                "dt_quality": {
                  "type": "string",
                  "enum": ["EXPLICIT", "DOCUMENT", "DATE_ONLY", "MISSING"]
                },
                "payload": { "type": "object" },
                "provenance": { "type": "object" }
              },
              "additionalProperties": true
            }
          },
          "rollups": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
